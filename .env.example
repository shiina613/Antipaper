# Copy to .env locally. Never commit credentials.
OPENAI_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=10
LLM_MAX_OUTPUT_TOKENS=1600
LLM_MAP_BATCH_CHARS=18000
LLM_MAP_CONCURRENCY=3
PROCESSING_DEADLINE_SECONDS=48
HISTORY_DB_PATH=.runtime/history.sqlite3

# Optional background related-document enrichment.
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_ALLOWED_DOMAINS=gov.vn,vnexpress.net
TAVILY_TIMEOUT_SECONDS=4
TAVILY_MAX_RESULTS=5
RELATED_DOCUMENT_MAX_REFERENCES=5

FRONTEND_ORIGIN=http://localhost:5173
