# Copy to .env locally. Never commit credentials.
OPENAI_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=25
LLM_MAX_OUTPUT_TOKENS=1600
LLM_MAP_BATCH_CHARS=24000
LLM_MAP_MAX_BATCH_CHARS=100000
LLM_MAP_TARGET_BATCHES=6
# Run the ~6 map batches in one wave. Keep MAX_LLM_CONCURRENCY >= LLM_MAP_CONCURRENCY.
LLM_MAP_CONCURRENCY=6
MAX_LLM_CONCURRENCY=6
LLM_MAP_BUDGET_SECONDS=55
LLM_REDUCE_BUDGET_SECONDS=20
LLM_QUESTIONS_BUDGET_SECONDS=20
LLM_PERSIST_RESERVE_SECONDS=5
MAX_ANALYZABLE_TEXT_CHARS=600000
PROCESSING_DEADLINE_SECONDS=110
# Max seconds allowed for native PDF/DOCX text extraction before the rest of the budget is
# reserved for the LLM report. Raise this for very large or scanned documents. Bounded by
# PROCESSING_DEADLINE_SECONDS.
INGESTION_DEADLINE_SECONDS=45
# Native table detection is the most expensive parsing step and holds the GIL, so it is
# bounded by a per-document time budget: text/citations are always fully extracted, and once
# this many seconds are spent detecting tables the remaining pages are read for text only.
# Lower it on constrained/serverless CPUs; INGESTION_EXTRACT_TABLES=0 disables detection.
INGESTION_TABLE_BUDGET_SECONDS=8
INGESTION_EXTRACT_TABLES=1
HISTORY_DB_PATH=.runtime/history.sqlite3

# Optional background related-document enrichment.
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_ALLOWED_DOMAINS=gov.vn,vnexpress.net
TAVILY_TIMEOUT_SECONDS=4
TAVILY_MAX_RESULTS=5
RELATED_DOCUMENT_MAX_REFERENCES=5

FRONTEND_ORIGIN=http://localhost:5173
