# Copy this file to `.env` and fill real values locally.
# Do not commit `.env`.

# LLM / AI runtime
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=1
EMBEDDING_MODEL=
MAX_LLM_CONCURRENCY=5

# Related-document web enrichment (strict domain allowlist)
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_ALLOWED_DOMAINS=gov.vn,vnexpress.net
TAVILY_TIMEOUT_SECONDS=8
TAVILY_MAX_RESULTS=5
RELATED_DOCUMENT_MAX_REFERENCES=8

# Release evaluation (judge and generator must be independently configured)
OPENAI_API_KEY=
EVAL_JUDGE_MODEL=gpt-5.4
EVAL_DATASET_PATH=evals/datasets/demo_v1.jsonl

# App runtime
MAX_FILE_MB=25
ARTIFACT_DIR=.artifacts
FRONTEND_ORIGIN=http://localhost:3000

# Demo data
DEMO_DOCUMENT_PATH=
BACKUP_DOCUMENT_PATH=
STRESS_DOCUMENT_PATH=
SMOKE_DOCUMENT_PATH=

# OCR / table fallback
ENABLE_TABLE_OCR=false
TABLE_OCR_DEVICE=cpu
