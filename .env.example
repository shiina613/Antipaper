# Copy this file to `.env` and fill real values locally.
# Do not commit `.env`.

# LLM / AI runtime
# Preferred OpenAI key; never commit real key.
OPENAI_API_KEY=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=1
LLM_MAX_OUTPUT_TOKENS=400
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=
EMBEDDING_TIMEOUT_SECONDS=20
EMBEDDING_MAX_RETRIES=1
EMBEDDING_MAX_BATCH_SIZE=64
EMBEDDING_MAX_TEXT_CHARS=8000
MAX_LLM_CONCURRENCY=5

# App runtime
MAX_FILE_MB=25
ARTIFACT_DIR=.artifacts
FRONTEND_ORIGIN=http://localhost:3000

# Demo data
DEMO_DOCUMENT_PATH=
BACKUP_DOCUMENT_PATH=
STRESS_DOCUMENT_PATH=
SMOKE_DOCUMENT_PATH=

# OCR / table fallback
ENABLE_TABLE_OCR=false
TABLE_OCR_DEVICE=cpu
